<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛡️ GuardCyberBot — Cybersecurity Awareness Assistant"
        Height="700" Width="900"
        MinHeight="600" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E27"
        FontFamily="Courier New">

    <Window.Resources>
        <!-- ── Colours ── -->
        <SolidColorBrush x:Key="BgDark"      Color="#0A0E27"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#12163A"/>
        <SolidColorBrush x:Key="BgInput"     Color="#1A1F3A"/>
        <SolidColorBrush x:Key="Green"       Color="#00FF41"/>
        <SolidColorBrush x:Key="GreenDark"   Color="#00BB30"/>
        <SolidColorBrush x:Key="Accent"      Color="#00D4FF"/>
        <SolidColorBrush x:Key="Warning"     Color="#FFB800"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#667799"/>

        <!-- ── Button Style ── -->
        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background"   Value="#00FF41"/>
            <Setter Property="Foreground"   Value="#0A0E27"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontFamily"   Value="Courier New"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00BB30"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#008820"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Secondary Button ── -->
        <Style x:Key="CyberButtonSecondary" TargetType="Button"
               BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="#1A2A4A"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#223355"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── TextBox Style ── -->
        <Style x:Key="CyberTextBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#1A1F3A"/>
            <Setter Property="Foreground"       Value="#00FF41"/>
            <Setter Property="BorderBrush"      Value="#00FF41"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CaretBrush"       Value="#00FF41"/>
            <Setter Property="FontFamily"       Value="Courier New"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="SelectionBrush"   Value="#00FF4160"/>
        </Style>

        <!-- ── Label Style ── -->
        <Style x:Key="CyberLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#00D4FF"/>
            <Setter Property="FontFamily"  Value="Courier New"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Margin"      Value="0,6,0,2"/>
        </Style>

        <!-- ── TabItem Style ── -->
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="#12163A"/>
            <Setter Property="Foreground"  Value="#667799"/>
            <Setter Property="FontFamily"  Value="Courier New"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A1F3A"/>
                    <Setter Property="Foreground" Value="#00FF41"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── DataGrid Style ── -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"          Value="#12163A"/>
            <Setter Property="Foreground"          Value="#00FF41"/>
            <Setter Property="BorderBrush"         Value="#00FF41"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="FontFamily"          Value="Courier New"/>
            <Setter Property="FontSize"            Value="11"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1A2A4A"/>
            <Setter Property="RowBackground"       Value="#0A0E27"/>
            <Setter Property="AlternatingRowBackground" Value="#10152A"/>
            <Setter Property="ColumnHeaderHeight"  Value="30"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="409*"/>
            <ColumnDefinition Width="41*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#12163A"
                BorderBrush="#00FF41" BorderThickness="0,0,0,1" Grid.ColumnSpan="2">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="🛡️" FontSize="26" Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="GuardCyberBot"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#00FF41"/>
                        <TextBlock Text="Cybersecurity Awareness Assistant — Part 3"
                                   FontSize="10" Foreground="#667799"/>
                    </StackPanel>
                </StackPanel>

                <!-- DB status indicator -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="20,0">
                    <Ellipse x:Name="ellDbStatus" Width="10" Height="10"
                             Fill="Gray" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtDbStatus" Text="DB: Checking..."
                               Foreground="#667799" FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ TAB CONTROL ═══════════════════════════════════════════ -->
        <TabControl Grid.Row="1"
                    Background="#0A0E27"
                    BorderBrush="#00FF41"
                    BorderThickness="0"
                    Padding="0" Grid.ColumnSpan="2">

            <!-- ─────────────────────────────────────────────────────
                 TAB 1: CHATBOT
                 ───────────────────────────────────────────────────── -->
            <TabItem Header="💬 Chat">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat history -->
                    <Border Grid.Row="0"
                            BorderBrush="#00FF41" BorderThickness="1"
                            CornerRadius="4" Margin="0,0,0,10">
                        <TextBox x:Name="txtChat"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#0D1128"
                                 Foreground="#00FF41"
                                 BorderThickness="0"
                                 FontFamily="Courier New"
                                 FontSize="12"
                                 Padding="12"/>
                    </Border>

                    <!-- Quick-action buttons -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                        <Button Content="🎮 Start Quiz"   Style="{StaticResource CyberButtonSecondary}"
                                Margin="0,0,8,4" Click="btnQuickQuiz_Click"/>
                        <Button Content="📋 Show Tasks"   Style="{StaticResource CyberButtonSecondary}"
                                Margin="0,0,8,4" Click="btnQuickTasks_Click"/>
                        <Button Content="📜 Activity Log" Style="{StaticResource CyberButtonSecondary}"
                                Margin="0,0,8,4" Click="btnQuickLog_Click"/>
                        <Button Content="❓ Help"          Style="{StaticResource CyberButtonSecondary}"
                                Margin="0,0,0,4"  Click="btnQuickHelp_Click"/>
                    </WrapPanel>

                    <!-- Input row -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtMessage"
                                 Grid.Column="0"
                                 Height="36"
                                 Style="{StaticResource CyberTextBox}"
                                 Margin="0,0,8,0"
                                 FontSize="13"
                                 KeyDown="txtMessage_KeyDown"/>

                        <Button Grid.Column="1"
                                Content="⚡ Send"
                                Style="{StaticResource CyberButton}"
                                Width="90" Height="36"
                                Click="btnSend_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────────────────────────────────
                 TAB 2: TASK MANAGER
                 ───────────────────────────────────────────────────── -->
            <TabItem Header="📋 Tasks">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add-task form -->
                    <Border Grid.Row="0"
                            Background="#12163A"
                            BorderBrush="#00D4FF"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Column="0" Grid.Row="0"
                                       Text="Task Title" Style="{StaticResource CyberLabel}"/>
                            <TextBlock Grid.Column="1" Grid.Row="0"
                                       Text="Reminder Date (optional)"
                                       Style="{StaticResource CyberLabel}" Margin="8,6,0,2"/>

                            <TextBox x:Name="txtTaskTitle"
                                     Grid.Column="0" Grid.Row="1"
                                     Height="32"
                                     Style="{StaticResource CyberTextBox}"
                                     Margin="0,0,8,0"/>

                            <DatePicker x:Name="dpReminder"
                                        Grid.Column="1" Grid.Row="1"
                                        Height="32"
                                        Background="#1A1F3A"
                                        Foreground="#00FF41"
                                        BorderBrush="#00D4FF"
                                        Margin="8,0,8,0"/>

                            <Button Grid.Column="2" Grid.Row="1"
                                    Content="➕ Add Task"
                                    Style="{StaticResource CyberButton}"
                                    Width="100" Height="32"
                                    Click="btnAddTask_Click"/>
                        </Grid>
                    </Border>

                    <!-- Task list -->
                    <DataGrid x:Name="dgTasks"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"          Binding="{Binding Id}"            Width="45"/>
                            <DataGridTextColumn Header="Status"      Binding="{Binding StatusDisplay}"  Width="80"/>
                            <DataGridTextColumn Header="Title"       Binding="{Binding Title}"          Width="180"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}"    Width="*"/>
                            <DataGridTextColumn Header="Reminder"    Binding="{Binding ReminderDisplay}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <Button Content="✅ Mark Complete"
                                Style="{StaticResource CyberButton}"
                                Width="140" Height="32"
                                Margin="0,0,10,0"
                                Click="btnCompleteTask_Click"/>
                        <Button Content="🗑️ Delete Task"
                                Style="{StaticResource CyberButtonSecondary}"
                                Width="120" Height="32"
                                Margin="0,0,10,0"
                                Click="btnDeleteTask_Click"/>
                        <Button Content="🔄 Refresh"
                                Style="{StaticResource CyberButtonSecondary}"
                                Width="90" Height="32"
                                Click="btnRefreshTasks_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────────────────────────────────
                 TAB 3: QUIZ
                 ───────────────────────────────────────────────────── -->
            <TabItem Header="🎮 Quiz">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Score bar -->
                    <Border Grid.Row="0"
                            Background="#12163A"
                            BorderBrush="#00D4FF"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,8" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtQuizStatus"
                                       Text="🎮 Press 'Start Quiz' to begin!"
                                       Foreground="#00D4FF" FontSize="13"/>
                            <TextBlock x:Name="txtScore"
                                       Grid.Column="1"
                                       Text="Score: 0 / 0"
                                       Foreground="#FFB800" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Question display -->
                    <Border Grid.Row="1"
                            Background="#0D1128"
                            BorderBrush="#00FF41"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="16">
                        <TextBlock x:Name="txtQuestion"
                                   Text="Press 'Start Quiz' to load the first question."
                                   Foreground="#00FF41"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </Border>

                    <!-- Answer buttons -->
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button x:Name="btnA" Content="A" Grid.Column="0" Grid.Row="0"
                                Style="{StaticResource CyberButtonSecondary}"
                                Height="44" Margin="0,0,6,6"
                                FontSize="13" Click="btnAnswer_Click"/>
                        <Button x:Name="btnB" Content="B" Grid.Column="1" Grid.Row="0"
                                Style="{StaticResource CyberButtonSecondary}"
                                Height="44" Margin="6,0,0,6"
                                FontSize="13" Click="btnAnswer_Click"/>
                        <Button x:Name="btnC" Content="C" Grid.Column="0" Grid.Row="1"
                                Style="{StaticResource CyberButtonSecondary}"
                                Height="44" Margin="0,0,6,0"
                                FontSize="13" Click="btnAnswer_Click"/>
                        <Button x:Name="btnD" Content="D" Grid.Column="1" Grid.Row="1"
                                Style="{StaticResource CyberButtonSecondary}"
                                Height="44" Margin="6,0,0,0"
                                FontSize="13" Click="btnAnswer_Click"/>
                    </Grid>

                    <!-- Start / feedback row -->
                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock x:Name="txtFeedback"
                                   Foreground="#FFB800"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>
                        <Button x:Name="btnStartQuiz"
                                Content="🎮 Start Quiz"
                                Style="{StaticResource CyberButton}"
                                Width="150" Height="36"
                                HorizontalAlignment="Left"
                                Click="btnStartQuiz_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─────────────────────────────────────────────────────
                 TAB 4: ACTIVITY LOG
                 ───────────────────────────────────────────────────── -->
            <TabItem Header="📜 Activity Log">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgLog"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"          Binding="{Binding Id}"          Width="50"/>
                            <DataGridTextColumn Header="Timestamp"  Binding="{Binding Timestamp, StringFormat='HH:mm  dd/MM/yyyy'}" Width="130"/>
                            <DataGridTextColumn Header="Action"     Binding="{Binding Action}"      Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                Margin="0,10,0,0">
                        <Button Content="🔄 Refresh Log"
                                Style="{StaticResource CyberButton}"
                                Width="130" Height="32"
                                Click="btnRefreshLog_Click"/>
                        <TextBlock x:Name="txtLogInfo"
                                   Text="  Showing last 10 actions"
                                   Foreground="#667799" FontSize="10"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ══ STATUS BAR ═══════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#12163A"
                BorderBrush="#00FF41" BorderThickness="0,1,0,0" Grid.ColumnSpan="2" Margin="0,594,0,0" Grid.RowSpan="2">
            <TextBlock x:Name="txtStatusBar"
                       Text="Ready. Type a message or use the tabs above."
                       Foreground="#667799" FontSize="10"
                       VerticalAlignment="Center" Margin="16,0"/>
        </Border>
    </Grid>
</Window>
